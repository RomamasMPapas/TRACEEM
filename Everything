                        rows: orders.map((doc) {
                          final data = doc.data() as Map<String, dynamic>;
                          final docId = doc.id;
                          final progress = (data['progress'] ?? 0.0).toDouble();
                          final status = data['status'] ?? 'Pending';

                          return DataRow(
                            cells: [
                              DataCell(
                                Text(
                                  data['orderNumber'] ?? 'N/A',
