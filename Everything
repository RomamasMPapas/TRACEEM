      // Default center pin when nothing is set yet
      if (_fromLatLng == null && _toLatLng == null)
        Marker(
          point: _initialCenter,
          width: 44,
          height: 44,
          child: const Icon(Icons.location_on, color: Colors.grey, size: 40),
